# Python bytecode and cache directories
__pycache__/
*.py[cod]
*$py.class

# Python build and packaging artifacts
build/
dist/
*.egg-info/

# Virtual environments created for local development
.venv/
venv/
env/

# Test and coverage output generated by Python tools
.pytest_cache/
.coverage
htmlcov/

# VS Code local workspace settings
# Keep personal editor preferences out of the shared repository.
.vscode/

# macOS system files
.DS_Store

# Docker and container temporary artifacts
# Keep generated container data/logs out of Git while allowing Docker config files.
*.log
tmp/
temp/
